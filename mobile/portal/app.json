{
  "expo": {
    "name": "Bakircilar Portal",
    "slug": "bakircilar-portal",
    "scheme": "bakircilar-portal",
    "version": "1.1.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#071127"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "bundleIdentifier": "com.bakircilar.portal",
      "supportsTablet": true
    },
    "android": {
      "versionCode": 11,
      "package": "com.bakircilar.portal",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#071127"
      },
      "softwareKeyboardLayoutMode": "resize"
    },
    "androidStatusBar": {
      "backgroundColor": "#071127",
      "barStyle": "light-content"
    },
    "androidNavigationBar": {
      "backgroundColor": "#060E1C",
      "barStyle": "light-content"
    },
    "plugins": [
      "expo-font",
      "expo-secure-store",
      "expo-notifications"
    ]
  }
}
