# Server Configuration
NODE_ENV=development
PORT=5000

# PostgreSQL Database
# PRODUCTION: Use 127.0.0.1 instead of localhost to avoid peer authentication issues
# Example: postgresql://postgres:password@127.0.0.1:5432/mikrob2b?schema=public
DATABASE_URL="postgresql://username:password@localhost:5432/mikrob2b?schema=public"

# JWT Secret (generate a random 32+ character string)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Mikro ERP Configuration
USE_MOCK_MIKRO=true
MIKRO_SERVER=
MIKRO_DATABASE=
MIKRO_USER=
MIKRO_PASSWORD=
MIKRO_PORT=1433
MIKRO_USER_NO=1

# CORS
FRONTEND_URL=http://localhost:3000

# Ziraat Nestpay PayByLink (bank-hosted card page; no StoreKey/3D form in B2B)
# Keep real values in .env.nestpay.local or NESTPAY_ENV_FILE, never commit them.
NESTPAY_ENABLED=false
NESTPAY_PROD_API_URL=https://sanalpos2.ziraatbank.com.tr/fim/api
NESTPAY_MERCHANT_ID=
NESTPAY_TERMINAL_ID=
NESTPAY_PROD_API_USERNAME=
NESTPAY_PROD_API_PASSWORD=
NESTPAY_OK_URL=http://localhost:3000/api/payments/nestpay/result/success
NESTPAY_FAIL_URL=http://localhost:3000/api/payments/nestpay/result/failure
NESTPAY_CALLBACK_URL=http://localhost:3000/api/payments/nestpay/callback
# Only fill these if Ziraat/Payten explicitly provides or requires them.
NESTPAY_ORIGIN=
NESTPAY_MERCHANT_IP=
NESTPAY_LINK_EXPIRY=1
NESTPAY_LINK_EXPIRY_UNIT=D
NESTPAY_MIN_TRANSACTION_AMOUNT=1
NESTPAY_MAX_TRANSACTION_AMOUNT=1000000
NESTPAY_MAX_BALANCE_AGE_HOURS=96
NESTPAY_REQUEST_TIMEOUT_MS=30000

# YolPilot read-only integration for open pending orders
YOLPILOT_INTEGRATION_API_KEY=change-this-long-random-key

# Cron Job
ENABLE_CRON=true
SYNC_CRON_SCHEDULE="0 * * * *"
VADE_SYNC_CRON_SCHEDULE="0 * * * *"
VADE_REMINDER_CRON_SCHEDULE="0 * * * *"

# Fiyat Listesi 6 canliya gecis ani (saat ve UTC offset iceren ISO-8601;
# ornek: 2026-07-23T14:30:00+03:00).
# Bu tarihten sonraki standart fiyat degisikliklerinde 13/14 de zorunlu sayilir.
PRICE_LIST_TIER6_CUTOVER_DATE=

# E-Invoice Upload + Auto Import
EINVOICE_UPLOAD_DIR=private-uploads/einvoices
EINVOICE_AUTO_IMPORT_ENABLED=false
EINVOICE_AUTO_IMPORT_CRON_SCHEDULE="*/20 * * * *"
EINVOICE_AUTO_IMPORT_SOURCE_DIR=/var/www/b2b/backend/auto-import/einvoices
EINVOICE_AUTO_IMPORT_ARCHIVE_DIR=/var/www/b2b/backend/auto-import/einvoices/_processed
EINVOICE_AUTO_IMPORT_PREFIXES=DEF26,DAR26
EINVOICE_AUTO_IMPORT_RECURSIVE=true
EINVOICE_AUTO_IMPORT_SKIP_EXISTING=true
EINVOICE_AUTO_IMPORT_DELETE_AFTER_IMPORT=false
EINVOICE_AUTO_IMPORT_MAX_FILES=500
